let msg = 'Hello, World!';let handleClick = function () {console.log('Hello, Mars!');};let btn = (function(){const elem = document.createElement('button');elem.setAttribute('type', "button");elem.addEventListener('click', handleClick);elem.append(msg);return elem})();let div1 = (function(){const elem = document.createElement('div');return elem})();let div2 = (function(){const elem = document.createElement('div');return elem})();