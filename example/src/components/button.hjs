import { ctx } from '../context.hjs'

export function button() {
	let efs = ctx.effects()
	let txt = ctx.signal('Click me!')

	function handleClick() {
		txt.set('Button clicked!')
	}

	let btn = (
		<button type="button" onClick=handleClick>
			txt.get()
		</button>
	);

	efs.effect(function () {
		btn.innerText = txt.get()
	})

	return btn
}
